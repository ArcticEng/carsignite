# ═══════════════════════════════════════════
# CarsIgnite Environment Configuration
# ═══════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=production

# Frontend URL (for CORS — set to your Vercel domain)
FRONTEND_URL=https://carsignite.vercel.app

# Database (Railway: use /data/carsignite.db with a volume mount)
DB_PATH=./db/carsignite.db

# JWT Auth
JWT_SECRET=CHANGE-THIS-TO-A-LONG-RANDOM-STRING

# Google Maps
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Admin
ADMIN_EMAIL=admin@carsignite.co.za
ADMIN_PASSWORD=CHANGE-THIS-TO-SECURE-PASSWORD

# PayFast (Production)
PAYFAST_MERCHANT_ID=your-live-merchant-id
PAYFAST_MERCHANT_KEY=your-live-merchant-key
PAYFAST_PASSPHRASE=your-payfast-passphrase
PAYFAST_URL=https://www.payfast.co.za/eng/process
PAYFAST_VALIDATE_URL=https://www.payfast.co.za/eng/query/validate
PAYFAST_RETURN_URL=https://carsignite.vercel.app/payment/success
PAYFAST_CANCEL_URL=https://carsignite.vercel.app/payment/cancel
PAYFAST_NOTIFY_URL=https://your-railway-app.up.railway.app/api/payfast/notify
